{
  "manifest_version": 3,
  "name": "Slide Live Relay",
  "version": "1.0.0",
  "description": "讀 Google 原生放映的當前頁，relay 到你的 Cloudflare，觀眾輸 PIN 看 live slide。",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "*://docs.google.com/*",
    "https://*/*"
  ],
  "action": { "default_popup": "popup.html", "default_title": "Slide Live Relay" },
  "options_page": "options.html",
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/presentation/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
